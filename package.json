{
  "name": "todo-list-jwt",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "server": "node ./bin/www",
    "client": "vite",
    "dev": "concurrently \"node ./bin/www\" \"vite\"",
    "dev:e2e": "concurrently \"node ./bin/www\" \"vite --host 127.0.0.1 --port 5173\"",
    "build": "vite build",
    "test": "jest --runInBand",
    "test:api": "jest expresslist/__tests__/api.test.js --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "supertest": "^7.1.4",
    "vite": "^7.1.10"
  }
}
